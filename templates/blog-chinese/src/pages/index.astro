---
import { getEmDashCollection, getSiteSettings } from 'emdash';
import Base from '../layouts/Base.astro';

const settings = await getSiteSettings();
const { entries: posts } = await getEmDashCollection('posts', {
  where: { status: 'published' },
  orderBy: { publishedAt: 'desc' },
  limit: settings?.postsPerPage || 10,
});

const formatDate = (date: string) => {
  if (!date) return '';
  return new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};
---

<Base title="首页">
  <!-- Hero 区域 -->
  <section class="mb-12 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
      🔮 器灵博客
    </h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      {settings?.description || '每个工具都有灵魂'}
    </p>
    <p class="text-sm text-gray-500 mt-2">
      70 = 器灵 | io70.com
    </p>
  </section>
  
  <!-- 文章列表 -->
  <section>
    <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
      <span>📝</span> 最新文章
    </h2>
    
    {posts.length > 0 ? (
      <div class="space-y-6">
        {posts.map((post: any, index: number) => (
          <article class="group">
            <a 
              href={`/posts/${post.slug}`}
              class="block p-6 bg-white rounded-xl border border-gray-100 hover:border-blue-200 hover:shadow-md transition-all"
            >
              <div class="flex flex-col md:flex-row gap-4">
                <!-- 文章信息 -->
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-2">
                    <time class="text-sm text-gray-500">
                      📅 {formatDate(post.publishedAt)}
                    </time>
                  </div>
                  
                  <h3 class="text-xl font-semibold text-gray-900 group-hover:text-blue-600 transition-colors mb-2">
                    {post.data.title}
                  </h3>
                  
                  {post.data.excerpt && (
                    <p class="text-gray-600 text-sm line-clamp-2">
                      {post.data.excerpt}
                    </p>
                  )}
                </div>
                
                <!-- 封面图 -->
                {post.data.featured_image?.src && (
                  <div class="w-full md:w-48 h-32 rounded-lg overflow-hidden shrink-0">
                    <img 
                      src={post.data.featured_image.src}
                      alt={post.data.featured_image.alt || post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-12 text-gray-500">
        <p class="text-lg">暂无文章</p>
        <p class="text-sm mt-2">请在后台添加文章</p>
      </div>
    )}
  </section>
</Base>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
