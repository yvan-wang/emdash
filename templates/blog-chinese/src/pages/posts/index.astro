---
import { getEmDashCollection, getSiteSettings } from 'emdash';
import Base from '../../layouts/Base.astro';

const settings = await getSiteSettings();
const { entries: posts, total } = await getEmDashCollection('posts', {
  where: { status: 'published' },
  orderBy: { publishedAt: 'desc' },
  limit: 50,
});

const formatDate = (date: string) => {
  if (!date) return '';
  return new Date(date).toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};
---

<Base title="全部文章" sidebar={false}>
  <section class="max-w-3xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">📝 全部文章</h1>
      <p class="text-gray-600">共 {total} 篇文章</p>
    </header>
    
    {posts.length > 0 ? (
      <div class="space-y-4">
        {posts.map((post: any) => (
          <article class="p-4 bg-white rounded-lg border border-gray-100 hover:border-blue-200 hover:shadow-sm transition-all">
            <a href={`/posts/${post.slug}`} class="block">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <h2 class="text-lg font-semibold text-gray-900 hover:text-blue-600 transition-colors">
                    {post.data.title}
                  </h2>
                  {post.data.excerpt && (
                    <p class="text-sm text-gray-600 mt-1 line-clamp-1">
                      {post.data.excerpt}
                    </p>
                  )}
                </div>
                <time class="text-sm text-gray-500 shrink-0">
                  {formatDate(post.publishedAt)}
                </time>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-12 text-gray-500">
        <p>暂无文章</p>
      </div>
    )}
  </section>
</Base>

<style>
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
